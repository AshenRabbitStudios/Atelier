{
  "name": "atelier",
  "version": "0.0.0",
  "description": "A legible, dockable, hot-reloadable desktop workbench for working with Claude.",
  "author": "",
  "license": "MIT",
  "main": "./out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "app:icon": "node scripts/make-icon.mjs",
    "app:pin": "powershell -ExecutionPolicy Bypass -File scripts/install-shortcut.ps1",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci:status": "node scripts/ci-status.mjs",
    "ci:check": "node scripts/ci-status.mjs --no-wait",
    "wt": "node scripts/worktree.mjs",
    "build:hologram": "esbuild plugins/hologram/entry.js --bundle --format=iife --outfile=plugins/hologram/hologram.bundle.js --platform=browser --legal-comments=none"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.195",
    "dockview": "7.0.2",
    "dockview-react": "7.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "shiki": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/rajdhani": "^5.2.7",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "42.5.0",
    "electron-vite": "5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "prettier": "^3.9.1",
    "three": "^0.160.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "7.3.6",
    "vitest": "^3.2.6"
  }
}
